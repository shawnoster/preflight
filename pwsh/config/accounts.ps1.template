# Preflight PowerShell — user configuration template.
#
# install.ps1 copies this to accounts.ps1 (gitignored) on first install.
# Edit accounts.ps1, not this file.
#
# This is the single source of truth for all op:// secret mappings.
# Edit paths to match your 1Password vault item names.
# Run `op item list` or `op item get <name>` to find yours.

# 1Password account shorthand. Run `op account list` to see yours.
# Examples: "my", "my-team", "my.1password.com"
$env:OP_ACCOUNT = 'change-me'

# Default AWS profile applied at session start (optional).
# $env:AWS_PROFILE_DEFAULT = 'my-dev-profile'

# ---- Secret map: env var → 1Password op:// reference -----------------------
# Import-OpEnv resolves every entry here into $env:* variables.
# Add, remove, or change paths freely — this file is gitignored.

$script:OpEnvMap = [ordered]@{
    # ---- Shared tooling (same item name across the team) --------------------
    ANTHROPIC_API_KEY      = 'op://Employee/Anthropic - API Key/credential'
    DATADOG_API_KEY        = 'op://Employee/Datadog - API Key - Self-Serve Workflow/credential'
    NPM_TOKEN              = 'op://Employee/npm - token - Local Development/credential'
    PACT_READONLY_PASSWORD = 'op://Engineering Tools - Dev/Pact Broker - Readonly/password'

    # ---- Personal (vault item names vary — update these to match yours) -----
    # ATLASSIAN_API_TOKEN    = 'op://Employee/Atlassian - VSCode/credential'
    # ATLASSIAN_EMAIL        = 'op://Employee/Atlassian - VSCode/username'
    # ATLASSIAN_SERVER_URL   = 'op://Employee/Atlassian - VSCode/hostname'
    # DATADOG_APP_KEY        = 'op://Employee/Datadog - Local - <YourName>/credential'
}
